{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArenaLeaderboardResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "$ref": "./arena-leaderboard-entry.json"
      }
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1
    },
    "sortBy": {
      "type": "string",
      "enum": [
        "winRate",
        "topFourRate",
        "averagePlacement",
        "matchesPlayed"
      ]
    },
    "sortOrder": {
      "type": "string",
      "enum": [
        "asc",
        "desc"
      ]
    },
    "totalItems": {
      "type": "integer",
      "minimum": 0
    },
    "totalPages": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "entries",
    "page",
    "pageSize",
    "sortBy",
    "sortOrder",
    "totalItems",
    "totalPages"
  ]
}
